# ================================
# Development Environment Variables
# ================================
# Copy this file to .env for local development

# Application
DEBUG=true
ENABLE_SWAGGER=true
# Change to a non-obvious path for security (e.g., /internal-api-docs)
# DOCS_URL=change-me
# REDOC_URL=change-me

# Paths
# Path to your cloned Twitch-Channel-Points-Miner-v2 repository
# You can use ~ for home directory (e.g., ~/Twitch-Channel-Points-Miner-v2)
MINER_REPO_PATH=/opt/Twitch-Channel-Points-Miner-v2

# Database
# SQLite database path (relative to project root or absolute path)
DATABASE_URL=sqlite+aiosqlite:///data/app.db

# Security
# Generate JWT_SECRET with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS
# For development, allow all origins (restrict in production!)
CORS_ORIGINS=["*"]

# Log Streaming
# Number of recent log lines to keep in memory for new connections
LOG_HISTORY_LINES=100
